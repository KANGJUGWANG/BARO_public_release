# BARO reproduction environment example
# Copy to .env.repro in a future implementation phase. Do not commit real values.
COMPOSE_PROJECT_NAME=baro-repro
REPRO_PROFILE=local-full
ARTIFACT_PROVIDER=rclone-private
ARTIFACT_BUNDLE_VERSION=<USER_INPUT>
ARTIFACT_ROOT=./reproduction/artifacts/extracted
# RCLONE_REMOTE=<USER_INPUT_OPTIONAL>
FRONTEND_HOST_PORT=8080
# BACKEND_DIAGNOSTIC_PORT=<USER_INPUT_OPTIONAL>
DB_HOST=mysql
DB_PORT=3306
DB_NAME=baro_repro
DB_USER=baro_repro_user
DB_PASSWORD=<GENERATE_ON_BOOTSTRAP>
MYSQL_ROOT_PASSWORD=<GENERATE_ON_BOOTSTRAP>
SNAPSHOT_TIER=minimal-repro
MODEL_BUNDLE_SUBDIR=baro-runtime-v1
MODEL_DIR=/app/runtime/models
JWT_SECRET=<GENERATE_ON_BOOTSTRAP>
ALLOWED_ORIGINS=http://localhost:8080
FRONTEND_URL=http://localhost:8080
# PUBLIC_BACKEND_ORIGIN=<USER_INPUT_OPTIONAL>
VITE_BACKEND_URL=/api
# VITE_KAKAO_JS_KEY=<USER_INPUT_OPTIONAL>
# KAKAO_REST_API_KEY=<USER_INPUT_OPTIONAL>
# KAKAO_REDIRECT_URI=<DERIVED_FROM_PUBLIC_ORIGIN>
# VITE_INTERNAL_APP_SHARING_URL=<USER_INPUT_OPTIONAL>
# VITE_APK_SHA256=<USER_INPUT_OPTIONAL>
# ARTIFACT_SOURCE=<USER_INPUT_OPTIONAL>
# ARTIFACT_MANIFEST_PATH=<USER_INPUT_OPTIONAL>
# ARTIFACT_MANIFEST_SHA256=<USER_INPUT_OPTIONAL>
ARTIFACT_CATEGORY=models
ARTIFACT_SNAPSHOT_TIER=minimal-repro
# RCLONE_RELEASE_PATH=<USER_INPUT_OPTIONAL>
DB_SNAPSHOT_TIER=minimal-repro
DB_SNAPSHOT_ROOT=./reproduction/artifacts/extracted/<ARTIFACT_BUNDLE_VERSION>/database/<DB_SNAPSHOT_TIER>
DB_SCHEMA_VERSION=baro-repro-db-v1
DB_RESTORE_BATCH_SIZE=500
DB_INIT_MODE=restore
DB_ALLOW_EXISTING_SAME_SNAPSHOT=false
